    "@okane-dokoitta/domain": "workspace:*",
    "@okane-dokoitta/importers": "workspace:*",
    "@okane-dokoitta/notifications": "workspace:*",
    "@okane-dokoitta/schemas": "workspace:*",
    "@simplewebauthn/server": "13.2.2",
    "fflate": "^0.8.2",
    "hash-wasm": "^4.12.0",
    "hono": "^4.9.0",
    "tsx": "^4.20.0",
    "uuid": "^11.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.0",
    "@types/node": "^22.15.0",
    "drizzle-orm": "^0.44.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
