  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env --import tsx --watch scripts/dev-lite.ts",
    "dev:postgres": "node --env-file-if-exists=../../.env --import tsx --watch src/server.ts",
    "dev:lite": "node --env-file-if-exists=../../.env --import tsx scripts/dev-lite.ts",
    "test": "vitest run",
