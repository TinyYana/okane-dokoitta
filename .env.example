# okane-dokoitta 環境變數（只有 key，沒有值 — AGENTS §7）
# 複製為 .env 後填值。任何未設定的選用整合（Discord、Push、AI）安靜停用。

# 啟用角色：api,worker,discord 任意組合（M1 只有 api）
OKANE_DOKOITTA_ROLES=

# docker-compose 的 postgres 容器密碼（compose 部署用；連線字串裡要用同一個）
OKANE_DOKOITTA_DB_PASSWORD=

# PostgreSQL 連線字串（app 執行用帳號，無 DDL 權限）
OKANE_DOKOITTA_DATABASE_URL=

# Migration 專用連線字串（有 DDL 權限；只在跑 migrate 時使用）
OKANE_DOKOITTA_MIGRATE_DATABASE_URL=

# 對外 URL（OAuth callback、Push、連結）
OKANE_DOKOITTA_BASE_URL=

# Session 簽章密鑰（隨機 32+ bytes）
OKANE_DOKOITTA_SESSION_SECRET=

# 多使用者註冊策略：open（公開）、invite（邀請碼，預設）、closed（關閉）
OKANE_DOKOITTA_REGISTRATION_MODE=

# 上傳檔案應用層加密金鑰（M3 起使用）
OKANE_DOKOITTA_FILE_KEY=

# 檔案落地目錄（預設 /data）
OKANE_DOKOITTA_DATA_DIR=

# 匯入原始檔保留天數（架設者可調整，預設 90）
OKANE_DOKOITTA_IMPORT_RETENTION_DAYS=

# 帳本預設時區（預設 Asia/Taipei）
OKANE_DOKOITTA_TZ=

# 美股／美國 ETF 自動報價（Finnhub API token，選填；台股 TWSE 報價不需要 token）
OKANE_DOKOITTA_FINNHUB_TOKEN=

# Discord 整合（M5，選填；Q10：需先在 Discord Developer Portal 建立 application）
OKANE_DOKOITTA_DISCORD_APP_ID=
OKANE_DOKOITTA_DISCORD_PUBLIC_KEY=
OKANE_DOKOITTA_DISCORD_BOT_TOKEN=
OKANE_DOKOITTA_DISCORD_CLIENT_SECRET=

# Web Push VAPID 金鑰對（M5，選填；用 web-push generate-vapid-keys 或等效工具產生）
OKANE_DOKOITTA_VAPID_PUBLIC_KEY=
OKANE_DOKOITTA_VAPID_PRIVATE_KEY=
OKANE_DOKOITTA_VAPID_CONTACT_EMAIL=

# （M1 單使用者：帳號在首次開啟網頁時的 first-run setup 建立，不經環境變數，
#  避免密碼進 env/compose 檔。M2 起有正式註冊流程。）

# （M6 AI：伺服器不需要任何 AI 變數——BYOK，每個使用者在設定頁自己接
#  OpenAI 相容端點，key 應用層加密存 DB。見 docs/SETUP_TUTORIAL.md §8。）
